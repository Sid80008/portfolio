# ──────────────────────────────────────────────────────────────
# .env.local  —  Copy this file, fill in your values, never commit it.
# ──────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://siddharthumajwal.com
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── Email (Resend — preferred) ────────────────────────────────
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address (must be verified in Resend dashboard)
EMAIL_FROM=portfolio@siddharthumajwal.com

# Where contact form submissions are delivered
EMAIL_TO=siddharthumajwal@gmail.com

# ── Email (Nodemailer / Gmail fallback) ───────────────────────
# Only used if RESEND_API_KEY is not set.
# Generate an App Password at https://myaccount.google.com/apppasswords
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Rate Limiting (Upstash Redis — preferred) ─────────────────
# Create a free Redis DB at https://console.upstash.com
# Leave blank to use in-memory fallback (dev/preview only)
UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Database (Neon PostgreSQL) ─────────────────────────────────
# Get your connection string at https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Error Tracking (Sentry) ───────────────────────────────────
# Create a project at https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX

# ── Authentication ───────────────────────────────────────────
# The passphrase used to log into the /admin dashboard.
ADMIN_PASSPHRASE=SIDDHARTHISADMIN
